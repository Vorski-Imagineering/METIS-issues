# Shared login gate secret for the METIS API.
# Get this from your METIS admin.
API_LOGIN_SECRET=your_shared_secret_here

# Google Sheets connector: base64 of your service-account JSON key (single line).
# Generate with:
#   echo "GOOGLE_SERVICE_ACCOUNT_B64=$(base64 -i ~/Downloads/your-key.json | tr -d '\n')" >> .env
GOOGLE_SERVICE_ACCOUNT_B64=your_base64_encoded_service_account_json
